import java.util.ArrayList; // Importação essencial
import java.util.Scanner;

class Estudante {
    private String nome;
    private double nota1;
    private double nota2;
    private double media;

    public Estudante(String nome, double nota1, double nota2, double media) {
        this.nome = nome;
        this.nota1 = nota1;
        this.nota2 = nota2;
        this.media = media;
    }

    public void exibirInfo() {
        System.out.println("Nome: " + nome + " | Média: " + media);
        boolean aprovado = media >= 6.0;
        System.out.println("Status: " + (aprovado ? "[x] Aprovado" : "[x] Reprovado"));
        System.out.println("--------------------------------------");
    }
}

public class Main {
    public static void main(String[] args) {
        Scanner leitor = new Scanner(System.in);
        
        // Criando a lista dinâmica de Estudantes
        ArrayList<Estudante> listaEstudantes = new ArrayList<>();
        
        String continuar;

        do {
            System.out.println("\n---- Cadastro de Estudante ----");

            System.out.print("Digite o nome: ");
            String nome = leitor.nextLine();

            System.out.print("Digite a 1º nota: ");
            double n1 = Double.parseDouble(leitor.nextLine());

            System.out.print("Digite a 2º nota: ");
            double n2 = Double.parseDouble(leitor.nextLine());

            double media = (n1 + n2) / 2;

            // ADICIONANDO NA LISTA: Usamos o método .add()
            listaEstudantes.add(new Estudante(nome, n1, n2, media));

            System.out.print("Deseja cadastrar outro aluno? (S/N): ");
            continuar = leitor.nextLine();

        } while (continuar.equalsIgnoreCase("S"));

        System.out.println("\n---- Relatório Geral (" + listaEstudantes.size() + " alunos) ----");
        
        // PERCORRENDO A LISTA: Usamos um "for-each"
        for (Estudante e : listaEstudantes) {
            e.exibirInfo();
        }

        System.out.println("Sistema encerrado.");
        leitor.close();
    }
}
